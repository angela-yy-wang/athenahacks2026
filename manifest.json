{
  "manifest_version": 3,
  "name": "Kairos",
  "description": "Find the best day to pay your tuition",
  "version": "1.0",
  "permissions": [
    "storage",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://*.cashnet.com/*", "https://pay.flywire.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "matches": ["https://*.cashnet.com/*", "https://pay.flywire.com/*"],
    "js": ["content.js"]
  }],
  "action": {
    "default_popup": "popup.html"
  }
}